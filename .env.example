# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Individual components (used by docker-compose and some scripts).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=continuous_claude
POSTGRES_USER=claude
POSTGRES_PASSWORD=CHANGE_ME

# Connection string(s). All OPC scripts check these in this order:
#   1. CONTINUOUS_CLAUDE_DB_URL  (preferred)
#   2. DATABASE_URL              (fallback)
#   3. OPC_POSTGRES_URL          (legacy, hooks only)
#
# There is NO hardcoded fallback in code (issue #62). If none of the three
# are set, scripts raise a clear error pointing back at this file.
#
# For local Docker dev: start `docker compose -f docker/docker-compose.yml up -d`,
# then copy docker/.env credentials into these variables (or export them
# from your shell).
CONTINUOUS_CLAUDE_DB_URL=postgresql://USER:PASSWORD@HOST:5432/continuous_claude?gssencmode=disable
# DATABASE_URL=
# OPC_POSTGRES_URL=

# ---------------------------------------------------------------------------
# API Keys (get your own)
# ---------------------------------------------------------------------------
# BRAINTRUST_API_KEY=
# NIA_API_KEY=
# MORPH_API_KEY=
# FIRECRAWLAPI_KEY=
